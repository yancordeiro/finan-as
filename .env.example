# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-256-bits-change-this

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# URLs
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080

# Database (already configured in docker-compose.yml)
# DATABASE_URL=postgres://financas:financas_dev_password@localhost:5432/financas_db?sslmode=disable

# Ollama AI Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
# Outros modelos disponíveis:
# - phi3:medium (mais leve, mais rápido)
# - mistral:7b (boa alternativa)
# - llama3.1:70b (muito melhor, requer mais RAM/GPU)
