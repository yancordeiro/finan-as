# Database
DATABASE_URL=postgres://financas:financas_dev_password@postgres:5432/financas_db?sslmode=disable

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-256-bits-change-this

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Server
PORT=8080
FRONTEND_URL=http://localhost:3000
